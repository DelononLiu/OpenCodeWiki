{
  "name": "opencodewiki",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash scripts/start.sh --watch",
    "start": "bash scripts/start.sh",
    "build": "npx tsc",
    "wiki": "node scripts/wiki.mjs",
    "index": "node scripts/index.mjs",
    "reindex": "node scripts/reindex.mjs",
    "watch": "node scripts/reindex.mjs --watch",
    "postinstall": "node scripts/postinstall.mjs",
    "setup": "npm install --ignore-scripts && node scripts/postinstall.mjs",
    "eval:qa": "EMBED_ENGINE=local LD_LIBRARY_PATH=node_modules/sharp/vendor/8.14.5/lib:$LD_LIBRARY_PATH node scripts/eval/runner.mjs",
    "eval:report": "node scripts/eval/report.mjs",
    "eval:answer": "node scripts/eval/answer-runner.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.22.1",
    "@huggingface/tokenizers": "^0.1.3",
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "onnxruntime-web": "^1.26.0",
    "openid-client": "^5.7.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
